# IAEDU Configuration for opencode-iaedu
# Copy this file to .env and fill in your values

# Required: Your IAEDU API key from iaedu.pt
IAEDU_API_KEY=your_api_key_here

# Required: Your IAEDU channel ID from iaedu.pt
IAEDU_CHANNEL_ID=your_channel_id_here

# Either set the endpoint directly:
IAEDU_ENDPOINT=https://api.iaedu.pt/agent-chat/api/v1/agent/your-agent-id/stream

# OR set the agent ID (the endpoint will be constructed automatically):
IAEDU_AGENT_ID=your_agent_id_here

# Optional: Override the base URL (defaults to https://api.iaedu.pt/agent-chat/api/v1)
# IAEDU_BASE_URL=https://api.iaedu.pt/agent-chat/api/v1
